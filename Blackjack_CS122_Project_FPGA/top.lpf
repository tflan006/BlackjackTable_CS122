// Debug wires for Logic Analyzer
LOCATE COMP "dbg[0]" SITE "K3";
IOBUF PORT "dbg[0]" DRIVE=4 IO_TYPE=LVCMOS33;
LOCATE COMP "dbg[1]" SITE "H3";
IOBUF PORT "dbg[1]" DRIVE=4 IO_TYPE=LVCMOS33;
LOCATE COMP "dbg[2]" SITE "K4";
IOBUF PORT "dbg[2]" DRIVE=4 IO_TYPE=LVCMOS33;
LOCATE COMP "dbg[3]" SITE "G4";
IOBUF PORT "dbg[3]" DRIVE=4 IO_TYPE=LVCMOS33;
LOCATE COMP "dbg[4]" SITE "F4";
IOBUF PORT "dbg[4]" DRIVE=4 IO_TYPE=LVCMOS33;
LOCATE COMP "dbg[5]" SITE "E4";
IOBUF PORT "dbg[5]" DRIVE=4 IO_TYPE=LVCMOS33;
LOCATE COMP "dbg[6]" SITE "D4";
IOBUF PORT "dbg[6]" DRIVE=4 IO_TYPE=LVCMOS33;
LOCATE COMP "dbg[7]" SITE "D5";
IOBUF PORT "dbg[7]" DRIVE=4 IO_TYPE=LVCMOS33;

