// Ports for SPI on the microcontroller
LOCATE COMP "data_cmd" SITE "C9";
IOBUF PORT "data_cmd" DRIVE=4 IO_TYPE=LVCMOS33;
LOCATE COMP "pico" SITE "C8";
IOBUF PORT "pico" IO_TYPE=LVCMOS33 HYSTERESIS=ON;
LOCATE COMP "sclk" SITE "C7";
IOBUF PORT "sclk" IO_TYPE=LVCMOS33 HYSTERESIS=ON;
LOCATE COMP "cs_n" SITE "C6";
IOBUF PORT "cs_n" IO_TYPE=LVCMOS33 HYSTERESIS=ON;

